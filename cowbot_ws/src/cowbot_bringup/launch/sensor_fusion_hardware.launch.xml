<?xml version="1.0" encoding="UTF-8"?>
<launch>

    <arg name="use_sim_time" default="False"/>
    <arg name="robot_name" default="cowbot"/>
    <arg name="robot_file" default="robot.urdf"/>
    <arg name="serial_port" default="/dev/arduino_nano"/>
    <arg name="baud_rate" default="57600"/>
    <arg name="loop_rate" default="30"/>
    <arg name="encoder_cpr" default="2550"/>

    <!-- Differential serial motor driver -->
    <include file="$(find-pkg-share serial_motor)/launch/serial_motor.launch.py">
        <arg name="robot_name" value="$(var robot_name)"/>
        <arg name="serial_port" value="$(var serial_port)"/>
        <arg name="baud_rate" value="$(var baud_rate)"/>
        <arg name="loop_rate" value="$(var loop_rate)"/>
        <arg name="encoder_cpr" value="$(var encoder_cpr)"/>
    </include>

    <!-- Robot state publisher -->
    <include file="$(find-pkg-share cowbot_description)/launch/robot_state_publisher.launch.py">
        <arg name="robot_name" value="$(var robot_name)"/>
        <arg name="robot_file" value="$(var robot_file)"/>
    </include>
    
    <!-- LSLiDAR ROS 2 driver -->
    <include file="$(find-pkg-share lslidar_driver)/launch/lslidar_launch.py"/>

    <!-- v4l2 Camera ROS 2 driver -->
    <!-- Raspberry Pi camera -->
    <node pkg="v4l2_camera" exec="v4l2_camera_node" name="v4l2_camera_node" output="screen">
        <param name="image_size" value="[800, 600]"/>
        <param name="camera_frame_id" value="$(var robot_name)_camera"/>
        <remap from="image_raw" to="/camera/image_raw"/>
        <remap from="camera_info" to="/camera/camera_info"/>
    </node>

    <!-- Camera Obstacle Detector -->
    <node pkg="cowbot_navigation" exec="camera_obstacle_detector" name="camera_obstacle_detector" output="screen"/>

    <!-- Robot Interface with Sensor Fusion -->
    <node pkg="cowbot_navigation" exec="robot_interface" name="robot_interface" output="screen">
        <param name="motors_enabled" value="False"/>
    </node>

    <!-- Robot Control with Sensor Fusion (optional - can be started separately) -->
    <!-- Uncomment to auto-start autonomous navigation -->
    <!-- <node pkg="cowbot_navigation" exec="robot_control" name="robot_control" output="screen"/> -->
    
</launch>
