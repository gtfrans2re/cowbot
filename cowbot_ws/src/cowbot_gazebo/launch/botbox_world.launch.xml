<?xml version='1.0'?>

<launch>
  <arg name="map_package" default="cowbot_description" description="Name of the map package" />
  <arg name="map_name" default="botbox_warehouse" description="Name of the map to simulate" />
  <arg name="use_crowdsim" default='0'/>
  <arg name="headless" default='0'/>

  <let name="world_path" value="$(find-pkg-share cowbot_gazebo)/worlds/$(var map_name).world" />
  <let name="model_path" value="$(find-pkg-share cowbot_gazebo)/models" />

  <!-- Use crowd sim if `use_crowdsim` is true-->
  <let name="menge_resource_path" if="$(var use_crowdsim)" value="$(find-pkg-share $(var map_package))/maps/$(var map_name)/config_resource"/>
  <let name="menge_resource_path" unless="$(var use_crowdsim)" value="" />

  <!-- Launch Gazebo Harmonic with or without GUI -->
  <let name="gui_arg" if="$(var headless)" value="-s" />
  <let name="gui_arg" unless="$(var headless)" value="-r" />
  
  <executable cmd="gz sim $(var gui_arg) $(var world_path)" output="both">
    <env name="GZ_SIM_RESOURCE_PATH" value="$(var model_path)" />
    <env name="MENGE_RESOURCE_PATH" value="$(var menge_resource_path)"/>
  </executable>

  <!-- ROS-Gazebo bridge for clock and other topics -->
  <node pkg="ros_gz_bridge" exec="parameter_bridge" name="ros_gz_bridge">
    <param name="config_file" value="$(find-pkg-share cowbot_gazebo)/config/ros_gz_bridge.yaml" />
  </node>

</launch>
